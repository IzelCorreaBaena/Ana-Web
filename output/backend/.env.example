# Server
NODE_ENV=development
PORT=4000
# Comma-separated list of allowed browser origins. Wildcard (*) is rejected in production.
ALLOWED_ORIGINS=http://localhost:5173
# Legacy single-origin variable (used if ALLOWED_ORIGINS is not set)
CORS_ORIGIN=http://localhost:5173

# Database (PostgreSQL)
DATABASE_URL=postgresql://postgres:postgres@localhost:5432/anacastellano?schema=public

# Auth (JWT) — MUST be at least 32 characters of cryptographically random data.
# Generate with:  openssl rand -base64 48
JWT_SECRET=replace-me-with-a-long-random-string-minimum-32-characters-please
JWT_EXPIRES_IN=7d

# Email (SMTP) — optional; if omitted, emails are logged to console only
SMTP_HOST=smtp.gmail.com
SMTP_PORT=587
SMTP_USER=
SMTP_PASS=
SMTP_FROM="Ana Castellano <no-reply@anacastellano.com>"

# Google Calendar integration — optional; all three required to enable
# Obtain from a Google Cloud service account with Calendar API access
GOOGLE_CLIENT_EMAIL=
GOOGLE_PRIVATE_KEY=
GOOGLE_CALENDAR_ID=

# Seed admin
ADMIN_EMAIL=admin@anacastellano.com
ADMIN_PASSWORD=changeme123
